# Data Guardian — Environment Configuration
#
# Copy this file to .env and fill in your values.
# The .env file is loaded at startup by the Rust backend.

# Groq AI API Key (optional)
# Used for AI-powered download size estimation in the Developer Sandbox.
# Get a free API key at: https://console.groq.com/keys
# Without this key, local estimation is used as fallback.
GROQ_API_KEY=
